registry=https://registry.npmjs.org/
@egox:registry=https://registry.npmjs.org/
# Auth token is provided at publish time:
#   - CI: NPM_TOKEN from the NPM_TOKEN secret (see .github/workflows/publish.yml)
#   - Local: `npm login` or set NPM_TOKEN in your environment (do NOT commit it)
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
